{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "APP/frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/admin",
            "dest": "/APP/frontend/admin.html"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/APP/frontend/assets/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/APP/frontend/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/APP/frontend/js/$1"
        },
        {
            "src": "/data/(.*)",
            "dest": "/APP/frontend/data/$1"
        },
        {
            "src": "/(.*\\.(html|ico|png|jpg|jpeg|svg|gif|webp))",
            "dest": "/APP/frontend/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/APP/frontend/index.html"
        }
    ]
}
